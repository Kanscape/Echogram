# Telegram Bot Token (必填)
# 从 @BotFather 获取
TG_BOT_TOKEN=

# Admin User ID (必填)
# 你的 Telegram User ID，拥有最高权限
ADMIN_USER_ID=

# Bot 名称
# 仅用于日志标识
BOT_NAME=Echogram

# 数据库路径
DB_PATH=data/echogram.db

# 日志等级
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Echogram Web API
WEB_DASHBOARD_HOST=127.0.0.1
WEB_DASHBOARD_PORT=8765
WEB_DASHBOARD_UI_URL=http://localhost:8080/dashboard
WEB_DASHBOARD_TOKEN=
WEB_DASHBOARD_AUTO_OPEN=false

# Docker Compose ports
ECHOGRAM_API_PORT=8765
ECHOGRAM_WEB_PORT=8080
